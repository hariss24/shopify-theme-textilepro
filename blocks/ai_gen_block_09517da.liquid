{% doc %}
  @prompt
    une barre de menu avec les catégories : menteaux; vestes; chemises; robes; pulls; pantalons; jeans; chaussure; sacs 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-category-menu-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
  }

  .ai-category-menu__container-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
    gap: {{ block.settings.item_spacing }}px;
    flex-wrap: wrap;
  }

  .ai-category-menu__item-{{ ai_gen_id }} {
    list-style: none;
  }

  .ai-category-menu__link-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.link_padding_vertical }}px {{ block.settings.link_padding_horizontal }}px;
    color: {{ block.settings.text_color }};
    text-decoration: none;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    border-radius: {{ block.settings.border_radius }}px;
    transition: all 0.3s ease;
    background-color: {{ block.settings.link_background_color }};
  }

  .ai-category-menu__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.text_hover_color }};
    background-color: {{ block.settings.link_hover_background_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-category-menu__container-{{ ai_gen_id }} {
      justify-content: {{ block.settings.mobile_alignment }};
      gap: {{ block.settings.mobile_item_spacing }}px;
    }

    .ai-category-menu__link-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_font_size }}px;
      padding: {{ block.settings.mobile_link_padding_vertical }}px {{ block.settings.mobile_link_padding_horizontal }}px;
    }
  }
{% endstyle %}

<category-menu-{{ ai_gen_id }} class="ai-category-menu-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <nav class="ai-category-menu__container-{{ ai_gen_id }}" role="navigation" aria-label="Catégories de produits">
    {% if block.settings.category_1_enabled %}
      <div class="ai-category-menu__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.category_1_url }}" class="ai-category-menu__link-{{ ai_gen_id }}">
          {{ block.settings.category_1_label }}
        </a>
      </div>
    {% endif %}

    {% if block.settings.category_2_enabled %}
      <div class="ai-category-menu__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.category_2_url }}" class="ai-category-menu__link-{{ ai_gen_id }}">
          {{ block.settings.category_2_label }}
        </a>
      </div>
    {% endif %}

    {% if block.settings.category_3_enabled %}
      <div class="ai-category-menu__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.category_3_url }}" class="ai-category-menu__link-{{ ai_gen_id }}">
          {{ block.settings.category_3_label }}
        </a>
      </div>
    {% endif %}

    {% if block.settings.category_4_enabled %}
      <div class="ai-category-menu__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.category_4_url }}" class="ai-category-menu__link-{{ ai_gen_id }}">
          {{ block.settings.category_4_label }}
        </a>
      </div>
    {% endif %}

    {% if block.settings.category_5_enabled %}
      <div class="ai-category-menu__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.category_5_url }}" class="ai-category-menu__link-{{ ai_gen_id }}">
          {{ block.settings.category_5_label }}
        </a>
      </div>
    {% endif %}

    {% if block.settings.category_6_enabled %}
      <div class="ai-category-menu__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.category_6_url }}" class="ai-category-menu__link-{{ ai_gen_id }}">
          {{ block.settings.category_6_label }}
        </a>
      </div>
    {% endif %}

    {% if block.settings.category_7_enabled %}
      <div class="ai-category-menu__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.category_7_url }}" class="ai-category-menu__link-{{ ai_gen_id }}">
          {{ block.settings.category_7_label }}
        </a>
      </div>
    {% endif %}

    {% if block.settings.category_8_enabled %}
      <div class="ai-category-menu__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.category_8_url }}" class="ai-category-menu__link-{{ ai_gen_id }}">
          {{ block.settings.category_8_label }}
        </a>
      </div>
    {% endif %}

    {% if block.settings.category_9_enabled %}
      <div class="ai-category-menu__item-{{ ai_gen_id }}">
        <a href="{{ block.settings.category_9_url }}" class="ai-category-menu__link-{{ ai_gen_id }}">
          {{ block.settings.category_9_label }}
        </a>
      </div>
    {% endif %}
  </nav>
</category-menu-{{ ai_gen_id }}>

<script>
  (function() {
    class CategoryMenu{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.links = this.querySelectorAll('.ai-category-menu__link-{{ ai_gen_id }}');
        this.highlightCurrentPage();
      }

      highlightCurrentPage() {
        const currentPath = window.location.pathname;
        this.links.forEach(link => {
          if (link.getAttribute('href') === currentPath) {
            link.style.fontWeight = '700';
          }
        });
      }
    }

    customElements.define('category-menu-{{ ai_gen_id }}', CategoryMenu{{ ai_gen_id }});
  })();
</script>

